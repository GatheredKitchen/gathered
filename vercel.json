{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/login/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/scan.js": {
      "maxDuration": 30
    }
  }
}
